# vine-relay build output
/vine-relay

# =============================================================================
# NeverCast .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# OS Generated Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
*~

# -----------------------------------------------------------------------------
# Editor / IDE Files
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
*.bak
*.tmp
*.orig
*~

# Cursor IDE
.cursor
.cursor/debug-*.log
.cursor/plans/

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Environment Files - NEVER commit secrets
# These files contain API keys, passwords, and tokens that must stay private.
# Only .env.example files (templates without real values) should be tracked.
# -----------------------------------------------------------------------------
.env
.env.local
.env.production
.env.staging
.env.development
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# Encrypted env files (defense in depth)
*.env.enc

# Keep example files tracked (these contain placeholder values only)
!**/.env.example

# -----------------------------------------------------------------------------
# SSL/TLS Certificates & Private Keys - CRITICAL: Never commit these
# Generated by certbot or manually; contain private key material
# -----------------------------------------------------------------------------
**/certbot/
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
*.jks
ssl-dhparams.pem

# Keep public keys that are intentionally tracked
!**/gir-public.pem

# -----------------------------------------------------------------------------
# Electron Build Outputs
# -----------------------------------------------------------------------------
dist/
out/
*.AppImage
*.dmg
*.exe
*.deb
*.rpm
*.snap
*.flatpak
*.msi
*.nsis
*.blockmap

# -----------------------------------------------------------------------------
# Authentication Files
# -----------------------------------------------------------------------------
app/nginx/.htpasswd
.htpasswd

# -----------------------------------------------------------------------------
# Encrypted Signaling Server
# The encrypted server and backups should not be committed.
# The encryption key is passed at runtime via SIGNALING_KEY env var.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Secret/Password Files - CRITICAL: Never commit these
# Any file containing keys, secrets, or passwords
# -----------------------------------------------------------------------------
.signaling_key
.signaling_secret
server/.signaling_key
*.secret
*_secret
*_SECRET
credentials.json
service-account*.json

# -----------------------------------------------------------------------------
# Key Vault - Encrypted key storage
# The encrypted-key.json contains the SIGNALING_KEY encrypted at rest.
# While it's encrypted, keeping it out of version control adds defense in depth.
# -----------------------------------------------------------------------------
app/key-vault/encrypted-key.json

# -----------------------------------------------------------------------------
# GIR Monitoring Logs & Config
# Encrypted security logs and container snapshots
# -----------------------------------------------------------------------------
monitor-logs/
*.enc
*.snapshot
tools/gir/url_monitor_config.json

# Keep example config tracked
!tools/gir/url_monitor_config.example.json

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Distribution / packaging
*.egg-info/
*.egg
build/
sdist/
wheels/
pip-wheel-metadata/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Node.js / JavaScript
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
.eslintcache
.parcel-cache

# -----------------------------------------------------------------------------
# C / C++ Build Artifacts (bloom/trellis)
# -----------------------------------------------------------------------------
*.o
*.obj
*.so
*.so.*
*.dylib
*.dll
*.a
*.lib
*.out
*.app
*.dSYM/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile.in
config.log
config.status

# WASM build output
*.wasm
*.wasm.map
*.wat

# Keep build directories but not their generated contents
bloom/trellis/bindings/wasm/build/
!bloom/trellis/bindings/wasm/build/.gitkeep

# -----------------------------------------------------------------------------
# C# / .NET (bloom examples)
# -----------------------------------------------------------------------------
[Bb]in/
[Oo]bj/
*.user
*.suo
*.userosscache
*.sln.docstates

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# Keep certbot log directory structure acknowledgment
!coturn/certbot/logs/.gitkeep

# -----------------------------------------------------------------------------
# Build Outputs
# -----------------------------------------------------------------------------
tools/gir/build/
app/server/bloom/dist/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.pid
*.seed
*.pid.lock
.cache/
.temp/
.tmp/

# Terraform (if used for infra)
*.tfstate
*.tfstate.backup
.terraform/